1. La lógica en el <script setup>

Necesitamos importar computed y watch de Vue para reaccionar cuando Inertia reciba el mensaje de éxito desde Laravel.
JavaScript

import { ref, computed, watch } from 'vue';
import { usePage } from '@inertiajs/vue3';

const page = usePage();
const flashSuccess = ref(null);
let timeoutId = null;

// Observamos los cambios en los props de flash
watch(
    () => page.props.flash.success,
    (newValue) => {
        if (newValue) {
            flashSuccess.value = newValue;

            // Limpiar cualquier temporizador previo si el usuario envía varios mensajes
            if (timeoutId) clearTimeout(timeoutId);

            // El mensaje desaparecerá tras 5 segundos
            timeoutId = setTimeout(() => {
                flashSuccess.value = null;
            }, 5000);
        }
    },
    { immediate: true }
);

