namespace App\Http\Controllers;

use Illuminate\Http\Request;
use App\Models\Contact; // Asegúrate de que el modelo exista
use Illuminate\Support\Facades\Redirect;

class ContactController extends Controller
{
    public function contact(Request $request)
    {
        // 1. Validamos la información
        $data = $request->validate([
            'name'    => 'required|string|max:255',
            'email'   => 'required|email|max:255',
            'message' => 'required|string|min:10',
        ]);

        // 2. Almacenamos en la base de datos
        Contact::create($data);

        // 3. Opcional: Podrías enviar un correo aquí
        // Mail::to('tu-email@ejemplo.com')->send(new ContactMail($data));

        // 4. Respondemos a Inertia
        return Redirect::back()->with('success', 'Mensaje guardado correctamente');
    }
}
